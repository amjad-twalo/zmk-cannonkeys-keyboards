if SHIELD_PHOTON_DONGLE

config ZMK_KEYBOARD_NAME
    default "Photon Dongle"

config ZMK_BOARD_COMPAT
    def_bool y

# Dongle is the USB HID device — USB must always be enabled
config ZMK_USB
    default y

# BLE is required for the split central to scan and connect to the peripheral
config ZMK_BLE
    default y

config BT_CTLR
    default BT

config ZMK_SPLIT
    default y

config ZMK_SPLIT_ROLE_CENTRAL
    default y

config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
    default 1

# 1 peripheral + 5 BLE profiles + 1 headroom
config BT_MAX_CONN
    default 7

config BT_MAX_PAIRED
    default 7

endif # SHIELD_PHOTON_DONGLE